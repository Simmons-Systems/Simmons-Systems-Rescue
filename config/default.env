# Tunable defaults for the autorun harness.
# Override values here are baked into the USB image at build time.
# To change after flashing, edit /default.env on the FAT32 partition of the
# rescue stick.

# Stress duration in seconds (default: 7200 = 2 hours)
STRESS_DURATION_SEC=7200

# Percent of MemAvailable to test with memtester (default: 95)
MEMTESTER_PCT=95

# Where on the FAT32 partition to drop results files
RESULTS_DIR=/run/results
